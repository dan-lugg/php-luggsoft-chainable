{
  "name": "luggsoft/chainable",
  "description": "PHP Chainables — a fluent, method-chaining library for PHP",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Dan Lugg",
      "email": "dan.lugg@gmail.com"
    }
  ],
  "support": {
    "issues": "https://github.com/dan-lugg/php-luggsoft-chainable/issues",
    "source": "https://github.com/dan-lugg/php-luggsoft-chainable"
  },
  "keywords": [
    "chainable",
    "functional",
    "fluent",
    "pipeline"
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "config": {
    "bin-dir": "bin",
    "sort-packages": true,
    "platform": {
      "php": "8.1.34"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --configuration=phpstan.neon.dist",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "docs": "phpdoc"
  },
  "autoload": {
    "psr-4": {
      "": "src/"
    },
    "files": [
      "src/Luggsoft/Chainable/Chain.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "": "tests/"
    }
  }
}
